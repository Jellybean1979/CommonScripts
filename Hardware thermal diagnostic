<body>

<header>
  <div class="header-inner">
    <div class="header-eyebrow">CPU Thermal Diagnostics — Automated Report</div>
    <h1>Thermal<span>Diag</span></h1>
    <div class="header-sub">$reportDate</div>
    <div class="header-meta">
      <div class="meta-chip"><span class="label">HOST</span> $hostname</div>
      <div class="meta-chip"><span class="label">CPU</span> $cpuName</div>
      <div class="meta-chip"><span class="label">MODE</span> $testMode</div>
      <div class="meta-chip"><span class="label">SAMPLES</span> $($samples.Count)</div>
    </div>
  </div>
</header>

<main>

  <!-- Summary Stats -->
  <div class="summary-grid">
    <div class="stat-card$(if ([double]$tempStats.Max -ge $ThermalThresholdC) {' danger'} elseif ([double]$tempStats.Max -ge 80) {' warn'} else {' ok'})">
      <div class="stat-label">Peak Temp</div>
      <div class="stat-value">$($tempStats.Max)<span class="unit">°C</span></div>
      <div class="stat-range">Min <b>$($tempStats.Min)°C</b> · Avg <b>$($tempStats.Avg)°C</b></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Peak Clock</div>
      <div class="stat-value">$($clockStats.Max)<span class="unit">MHz</span></div>
      <div class="stat-range">Min <b>$($clockStats.Min)</b> · Avg <b>$($clockStats.Avg)</b></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Peak Load</div>
      <div class="stat-value">$($loadStats.Max)<span class="unit">%</span></div>
      <div class="stat-range">Min <b>$($loadStats.Min)%</b> · Avg <b>$($loadStats.Avg)%</b></div>
    </div>
    <div class="stat-card$(if ($throttleCount -gt 0) {' danger'} else {' ok'})">
      <div class="stat-label">Throttle Events</div>
      <div class="stat-value">$throttleCount<span class="unit">×</span></div>
      <div class="stat-range">Thermal threshold <b>${ThermalThresholdC}°C</b> · Clock drop <b>$(($ClockDropPct * 100))%</b></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Duration</div>
      <div class="stat-value">$DurationSeconds<span class="unit">s</span></div>
      <div class="stat-range">Interval <b>${SampleIntervalSec}s</b> · Threads <b>$StressThreads</b></div>
    </div>
  </div>

  <!-- Throttle Banner -->
  $(if ($throttleCount -gt 0) {
    "<div class='throttle-banner'><div class='throttle-icon'>⚠</div><div class='throttle-text'><strong>$throttleCount throttling event(s) detected</strong><span>CPU was throttled during this test run. Review the charts and table below for affected time windows.</span></div></div>"
  } else {
    "<div class='throttle-banner none'><div class='throttle-icon'>✓</div><div class='throttle-text'><strong>No throttling detected</strong><span>CPU maintained stable clocks and temperatures throughout the test.</span></div></div>"
  })

  <!-- Charts -->
  <div class="section-title">Performance Over Time</div>
  <div class="charts-grid">

    <div class="chart-card wide">
      <div class="chart-title">CPU Temperature (°C)</div>
      <div class="chart-canvas-wrap tall"><canvas id="chartTemp"></canvas></div>
    </div>

    <div class="chart-card">
      <div class="chart-title">CPU Clock Speed (MHz)</div>
      <div class="chart-canvas-wrap"><canvas id="chartClock"></canvas></div>
    </div>

    <div class="chart-card">
      <div class="chart-title">CPU Load (%)</div>
      <div class="chart-canvas-wrap"><canvas id="chartLoad"></canvas></div>
    </div>

    $(if (($samples | Where-Object { $_.Fan_RPM -ne "" }).Count -gt 0) {
      "<div class='chart-card wide'><div class='chart-title'>Fan Speed (RPM)</div><div class='chart-canvas-wrap'><canvas id='chartFan'></canvas></div></div>"
    })

  </div>

  <!-- Data Table -->
  <div class="section-title">Sample Log</div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Timestamp</th>
          <th>Temp (°C)</th>
          <th>Clock (MHz)</th>
          <th>Load (%)</th>
          <th>Fan (RPM)</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        $tableRows
      </tbody>
    </table>
  </div>

</main>

<footer>
  <p>Generated by ThermalDiag v2.0 — $reportDate</p>
</footer>

<script>
const labels  = [$jsLabels];
const temps   = [$jsTemps];
const clocks  = [$jsClocks];
const loads   = [$jsLoads];
const fans    = [$jsFans];
const throttleIdx = new Set([$jsThrottleIdx]);

const defGrid = {
  color: 'rgba(255,255,255,0.05)',
};
const defTick = {
  color: '#6e7681',
  font: { family: "'Share Tech Mono', monospace", size: 10 }
};
const defTooltip = {
  backgroundColor: '#161b22',
  borderColor: '#21262d',
  borderWidth: 1,
  titleColor: '#c9d1d9',
  bodyColor: '#8b949e',
  titleFont: { family: "'Share Tech Mono', monospace", size: 11 },
  bodyFont: { family: "'Share Tech Mono', monospace", size: 11 },
  padding: 10,
  cornerRadius: 4,
};

// Throttle band plugin — shades throttled samples red
const throttleBands = {
  id: 'throttleBands',
  beforeDraw(chart) {
    const {ctx, chartArea: {top, bottom}, scales: {x}} = chart;
    if (!x) return;
    ctx.save();
    throttleIdx.forEach(i => {
      const xPos = x.getPixelForValue(i);
      const w = x.getPixelForValue(1) - x.getPixelForValue(0);
      ctx.fillStyle = 'rgba(244,67,54,0.12)';
      ctx.fillRect(xPos - w/2, top, w, bottom - top);
    });
    ctx.restore();
  }
};

function makeChart(id, label, data, color, yLabel) {
  const ctx = document.getElementById(id);
  if (!ctx) return;
  new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [{
        label,
        data,
        borderColor: color,
        backgroundColor: color + '18',
        borderWidth: 1.5,
        pointRadius: 2,
        pointHoverRadius: 5,
        tension: 0.3,
        fill: true,
        spanGaps: true,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: { duration: 600, easing: 'easeInOutQuart' },
      plugins: {
        legend: { display: false },
        tooltip: { ...defTooltip, mode: 'index', intersect: false },
      },
      scales: {
        x: {
          ticks: {
            ...defTick,
            maxTicksLimit: 12,
            maxRotation: 0,
          },
          grid: defGrid,
          border: { color: '#21262d' }
        },
        y: {
          ticks: { ...defTick },
          grid: defGrid,
          border: { color: '#21262d' },
          title: { display: !!yLabel, text: yLabel, color: '#6e7681',
                   font: { family: "'Share Tech Mono', monospace", size: 10 } }
        }
      }
    },
    plugins: [throttleBands]
  });
}

// Temp chart gets a danger-zone fill
(function() {
  const ctx = document.getElementById('chartTemp');
  if (!ctx) return;
  const threshold = $ThermalThresholdC;
  new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [{
        label: 'CPU Temp',
        data: temps,
        borderColor: '#ff9800',
        backgroundColor: (ctx) => {
          const chart = ctx.chart;
          const {ctx: c, chartArea} = chart;
          if (!chartArea) return 'rgba(255,152,0,.1)';
          const grad = c.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);
          grad.addColorStop(0,   'rgba(244,67,54,.35)');
          grad.addColorStop(0.4, 'rgba(255,152,0,.2)');
          grad.addColorStop(1,   'rgba(255,152,0,.02)');
          return grad;
        },
        borderWidth: 2,
        pointRadius: 2,
        pointHoverRadius: 5,
        tension: 0.35,
        fill: true,
        spanGaps: true,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: { duration: 800 },
      plugins: {
        legend: { display: false },
        tooltip: { ...defTooltip, mode: 'index', intersect: false,
          callbacks: { label: ctx => ' ' + ctx.parsed.y + ' °C' }
        },
        annotation: {}
      },
      scales: {
        x: {
          ticks: { ...defTick, maxTicksLimit: 14, maxRotation: 0 },
          grid: defGrid,
          border: { color: '#21262d' }
        },
        y: {
          ticks: { ...defTick },
          grid: defGrid,
          border: { color: '#21262d' },
          suggestedMin: 30,
        }
      }
    },
    plugins: [
      throttleBands,
      {
        id: 'thresholdLine',
        afterDraw(chart) {
          const {ctx: c, chartArea, scales: {y}} = chart;
          if (!y) return;
          const yPos = y.getPixelForValue(threshold);
          if (yPos < chartArea.top || yPos > chartArea.bottom) return;
          c.save();
          c.setLineDash([6, 4]);
          c.strokeStyle = 'rgba(244,67,54,0.5)';
          c.lineWidth = 1;
          c.beginPath();
          c.moveTo(chartArea.left, yPos);
          c.lineTo(chartArea.right, yPos);
          c.stroke();
          c.fillStyle = 'rgba(244,67,54,0.7)';
          c.font = "10px 'Share Tech Mono', monospace";
          c.fillText('thermal limit ' + threshold + '°C', chartArea.left + 6, yPos - 5);
          c.restore();
        }
      }
    ]
  });
})();

makeChart('chartClock', 'Clock MHz',  clocks, '#00e5ff',  'MHz');
makeChart('chartLoad',  'Load %',     loads,  '#00e676',  '%');
makeChart('chartFan',   'Fan RPM',    fans,   '#b39ddb',  'RPM');
</script>

</body>
</html>
"@

$html | Out-File $OutputHTML -Encoding UTF8

# -- Final Summary -------------------------------------------------------------
Write-Host ""
Write-Host "  +----------------------------------------------------------+" -ForegroundColor DarkCyan
Write-Host "  |  RESULTS SUMMARY                                         |" -ForegroundColor DarkCyan
Write-Host "  +----------------------------------------------------------+" -ForegroundColor DarkCyan
Write-Host ("  |  Peak Temp   : {0,-10}  Avg: {1,-10}  Min: {2,-8}  |" -f
    "$($tempStats.Max) degC", "$($tempStats.Avg) degC", "$($tempStats.Min) degC") -ForegroundColor White
Write-Host ("  |  Peak Clock  : {0,-10}  Avg: {1,-10}  Min: {2,-8}  |" -f
    "$($clockStats.Max) MHz", "$($clockStats.Avg) MHz", "$($clockStats.Min) MHz") -ForegroundColor White
Write-Host ("  |  Peak Load   : {0,-10}  Avg: {1,-10}  Min: {2,-8}  |" -f
    "$($loadStats.Max) %", "$($loadStats.Avg) %", "$($loadStats.Min) %") -ForegroundColor White
Write-Host ("  |  Throttle Events : {0,-38} |" -f $throttleCount) -ForegroundColor $(if ($throttleCount -gt 0) { "Red" } else { "Green" })
Write-Host "  +----------------------------------------------------------+" -ForegroundColor DarkCyan
Write-Host ("  |  CSV  : {0,-49} |" -f $OutputCSV)  -ForegroundColor DarkGray
Write-Host ("  |  HTML : {0,-49} |" -f $OutputHTML) -ForegroundColor DarkGray
Write-Host "  +----------------------------------------------------------+" -ForegroundColor DarkCyan
Write-Host ""

# Auto-open the HTML report
try { Start-Process $OutputHTML } catch {}
Write-Status "Done. HTML report opened in default browser." "Green"
