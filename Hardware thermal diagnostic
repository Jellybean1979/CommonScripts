# ==============================================================================
#  CPU THERMAL STRESS DIAGNOSTICS  v2.0
# ==============================================================================
#  Built-in parallel CPU stress test | Throttle detection | HTML report
# ==============================================================================

param(
    [int]   $DurationSeconds   = 120,    # Total run time (stress + monitor)
    [int]   $SampleIntervalSec = 3,      # Seconds between data samples
    [int]   $ThermalThresholdC = 90,     # Temp ( degC) flagged as thermal throttle
    [float] $ClockDropPct      = 0.15,   # Fractional clock drop to flag power throttle
    [int]   $StressThreads     = 0,      # 0 = auto (all logical cores)
    [switch]$NoStressTest                # Monitor only, no load generation
)

# -- Output paths --------------------------------------------------------------
$stamp      = (Get-Date).ToString('yyyyMMdd_HHmmss')
$OutputCSV  = "$env:USERPROFILE\Documents\ThermalDiag_$stamp.csv"
$OutputHTML = "$env:USERPROFILE\Documents\ThermalDiag_$stamp.html"

# -- Helpers --------------------------------------------------------------------
function Write-Banner {
    Clear-Host
    Write-Host ""
    Write-Host "  ########+##+  ##+#######+######+ ###+   ###+ #####+ ##+      " -ForegroundColor Cyan
    Write-Host "     ##+==+##|  ##|##+====+##+==##+####+ ####|##+==##+##|      " -ForegroundColor Cyan
    Write-Host "     ##|   #######|#####+  ######++##+####+##|#######|##|      " -ForegroundColor Cyan
    Write-Host "     ##|   ##+==##|##+==+  ##+==##+##|+##++##|##+==##|##|      " -ForegroundColor DarkCyan
    Write-Host "     ##|   ##|  ##|#######+##|  ##|##| +=+ ##|##|  ##|#######+ " -ForegroundColor DarkCyan
    Write-Host "     +=+   +=+  +=++======++=+  +=++=+     +=++=+  +=++======+ " -ForegroundColor DarkCyan
    Write-Host "  DIAGNOSTICS v2.0  -  Stress - Monitor - Throttle Detection   " -ForegroundColor DarkGray
    Write-Host ""
}

function Write-Status ($msg, $color = "White") {
    Write-Host "  [$(Get-Date -Format 'HH:mm:ss')]  $msg" -ForegroundColor $color
}

# -- Try loading OpenHardwareMonitor --------------------------------------------
$ohmPath = "C:\Program Files\OpenHardwareMonitor\OpenHardwareMonitorLib.dll"
$computer = $null
if (Test-Path $ohmPath) {
    try {
        [void][Reflection.Assembly]::LoadFile($ohmPath)
        $computer = New-Object OpenHardwareMonitor.Hardware.Computer
        $computer.CPUEnabled          = $true
        $computer.MainboardEnabled    = $true
        $computer.FanControllerEnabled = $true
        $computer.Open()
        Write-Status "OpenHardwareMonitor loaded - full sensor data available." "Green"
    } catch {
        Write-Status "OHM found but failed to load: $_" "Yellow"
        $computer = $null
    }
} else {
    Write-Status "OpenHardwareMonitor not found - using WMI/PerfCounter fallback." "Yellow"
    Write-Status "Install OHM for temp + fan sensor data: openHardwareMonitor.org" "DarkGray"
}

# -- CPU Stress Test via Runspaces ----------------------------------------------
$stressRunspaces = @()
$stressHandles   = @()

if (-not $NoStressTest) {
    $logicalCores = (Get-CimInstance Win32_ComputerSystem).NumberOfLogicalProcessors
    if ($StressThreads -le 0) { $StressThreads = $logicalCores }

    Write-Status "Spawning $StressThreads stress threads across $logicalCores logical cores..." "Cyan"

    $stressScript = {
        param($DurationSeconds)
        $end = [DateTime]::UtcNow.AddSeconds($DurationSeconds)
        $x   = [double]1.0000001
        while ([DateTime]::UtcNow -lt $end) {
            # Tight floating-point loop - maximises IPC and thermal load
            for ($i = 0; $i -lt 500000; $i++) {
                $x = [Math]::Sqrt($x * 1.0000001 + 0.0000001)
                $x = [Math]::Sin($x) * [Math]::Cos($x) + 1.0000001
            }
        }
    }

    $pool = [RunspaceFactory]::CreateRunspacePool(1, $StressThreads)
    $pool.Open()

    for ($t = 0; $t -lt $StressThreads; $t++) {
        $ps = [PowerShell]::Create()
        $ps.RunspacePool = $pool
        [void]$ps.AddScript($stressScript).AddArgument($DurationSeconds)
        $stressRunspaces += $ps
        $stressHandles   += $ps.BeginInvoke()
    }

    Write-Status "Stress test running for $DurationSeconds seconds." "Cyan"
} else {
    Write-Status "Stress test skipped (monitor-only mode)." "DarkGray"
}

# -- CSV Header -----------------------------------------------------------------
"Timestamp,CPU_Temp_C,CPU_Clock_MHz,CPU_Load_Pct,Thermal_Throttle,Clock_Throttle,Fan_RPM" |
    Out-File $OutputCSV -Encoding UTF8

# -- Data Collection Loop -------------------------------------------------------
$samples      = [System.Collections.Generic.List[PSObject]]::new()
$maxClock     = 0.0
$throttleCount = 0
$elapsed      = 0

Write-Status "Collecting samples every $SampleIntervalSec s  (Ctrl+C to stop early)." "White"
Write-Host ""
Write-Host ("  {0,-20}  {1,8}  {2,10}  {3,8}  {4,10}  {5,8}" -f
    "Timestamp","Temp  degC","Clock MHz","Load %","Throttle","Fan RPM") -ForegroundColor DarkGray
Write-Host ("  " + ("-" * 75)) -ForegroundColor DarkGray

$stopwatch = [Diagnostics.Stopwatch]::StartNew()

try {
    while ($stopwatch.Elapsed.TotalSeconds -lt $DurationSeconds) {

        $ts       = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
        $cpuTemp  = ""
        $cpuClock = ""
        $cpuLoad  = ""
        $fanRPM   = ""

        # -- OHM sensor read --------------------------------------------------
        if ($computer) {
            foreach ($hw in $computer.Hardware) {
                $hw.Update()
                if ($hw.HardwareType -eq "CPU") {
                    foreach ($s in $hw.Sensors) {
                        if ($s.SensorType -eq "Temperature" -and $s.Name -like "*Package*") {
                            $cpuTemp = [math]::Round($s.Value, 1)
                        }
                        if ($s.SensorType -eq "Clock" -and $s.Name -like "*Core #1*") {
                            $cpuClock = [math]::Round($s.Value, 0)
                        }
                        if ($s.SensorType -eq "Load" -and $s.Name -eq "CPU Total") {
                            $cpuLoad = [math]::Round($s.Value, 1)
                        }
                    }
                }
                if ($hw.HardwareType -eq "Mainboard") {
                    foreach ($s in $hw.Sensors) {
                        if ($s.SensorType -eq "Fan" -and -not $fanRPM) {
                            $fanRPM = [math]::Round($s.Value, 0)
                        }
                    }
                }
            }
        }

        # -- Fallback - PerfCounter for load ---------------------------------
        if ($cpuLoad -eq "") {
            try {
                $cpuLoad = [math]::Round(
                    (Get-Counter '\Processor(_Total)\% Processor Time').CounterSamples.CookedValue, 1)
            } catch { $cpuLoad = "" }
        }

        # -- Throttle detection -----------------------------------------------
        $thermalFlag = $false
        $clockFlag   = $false

        if ($cpuTemp -ne "" -and [double]$cpuTemp -ge $ThermalThresholdC) {
            $thermalFlag = $true
        }

        if ($cpuClock -ne "") {
            $clkVal = [double]$cpuClock
            if ($clkVal -gt $maxClock) { $maxClock = $clkVal }
            # Flag if clock has dropped >$ClockDropPct from peak AND load is high
            if ($maxClock -gt 0 -and $cpuLoad -ne "" -and [double]$cpuLoad -gt 75) {
                if ($clkVal -lt $maxClock * (1 - $ClockDropPct)) { $clockFlag = $true }
            }
        }

        $anyThrottle = $thermalFlag -or $clockFlag
        if ($anyThrottle) { $throttleCount++ }

        # -- Store sample -----------------------------------------------------
        $row = [PSCustomObject]@{
            Timestamp      = $ts
            CPU_Temp_C     = $cpuTemp
            CPU_Clock_MHz  = $cpuClock
            CPU_Load_Pct   = $cpuLoad
            Thermal_Throttle = [int]$thermalFlag
            Clock_Throttle   = [int]$clockFlag
            Fan_RPM        = $fanRPM
        }
        $samples.Add($row)
        "$ts,$cpuTemp,$cpuClock,$cpuLoad,$([int]$thermalFlag),$([int]$clockFlag),$fanRPM" |
            Out-File $OutputCSV -Append -Encoding UTF8

        # -- Console row ------------------------------------------------------
        $tColor = if ($anyThrottle) { "Red" } elseif ($cpuTemp -gt 80) { "Yellow" } else { "Green" }
        $tFlag  = if ($anyThrottle) { "!! THROTTLE" } else { "  OK" }
        Write-Host ("  {0,-20}  {1,8}  {2,10}  {3,8}  {4,10}  {5,8}" -f
            $ts, $cpuTemp, $cpuClock, $cpuLoad, $tFlag, $fanRPM) -ForegroundColor $tColor

        Start-Sleep -Seconds $SampleIntervalSec
    }
}
finally {
    # -- Stop stress threads --------------------------------------------------
    if ($stressRunspaces.Count -gt 0) {
        Write-Host ""
        Write-Status "Stopping stress threads..." "DarkGray"
        foreach ($ps in $stressRunspaces) { $ps.Stop(); $ps.Dispose() }
        $pool.Close(); $pool.Dispose()
    }
    if ($computer) { $computer.Close() }
    $stopwatch.Stop()
}

# -- Summary stats --------------------------------------------------------------
$validTemps  = $samples | Where-Object { $_.CPU_Temp_C  -ne "" } | ForEach-Object { [double]$_.CPU_Temp_C  }
$validClocks = $samples | Where-Object { $_.CPU_Clock_MHz -ne "" } | ForEach-Object { [double]$_.CPU_Clock_MHz }
$validLoads  = $samples | Where-Object { $_.CPU_Load_Pct -ne "" } | ForEach-Object { [double]$_.CPU_Load_Pct  }

function Get-Stats($arr) {
    if (-not $arr -or $arr.Count -eq 0) { return @{ Min="N/A"; Max="N/A"; Avg="N/A" } }
    @{
        Min = [math]::Round(($arr | Measure-Object -Minimum).Minimum, 1)
        Max = [math]::Round(($arr | Measure-Object -Maximum).Maximum, 1)
        Avg = [math]::Round(($arr | Measure-Object -Average).Average, 1)
    }
}

$tempStats  = Get-Stats $validTemps
$clockStats = Get-Stats $validClocks
$loadStats  = Get-Stats $validLoads

# -- Build HTML Report ----------------------------------------------------------
Write-Host ""
Write-Status "Generating HTML report..." "Cyan"

# Serialise samples to JS arrays
function To-JsArray($prop) {
    ($samples | ForEach-Object { 
        $v = $_.$prop
        if ($v -eq "" -or $null -eq $v) { "null" } else { $v }
    }) -join ","
}

$jsLabels  = ($samples | ForEach-Object { '"' + $_.Timestamp.Substring(11,8) + '"' }) -join ","
$jsTemps   = To-JsArray "CPU_Temp_C"
$jsClocks  = To-JsArray "CPU_Clock_MHz"
$jsLoads   = To-JsArray "CPU_Load_Pct"
$jsFans    = To-JsArray "Fan_RPM"

# Throttle event indices for chart annotations
$throttleIndices = @()
for ($i = 0; $i -lt $samples.Count; $i++) {
    if ($samples[$i].Thermal_Throttle -eq 1 -or $samples[$i].Clock_Throttle -eq 1) {
        $throttleIndices += $i
    }
}
$jsThrottleIdx = if ($throttleIndices.Count -gt 0) { $throttleIndices -join "," } else { "" }

# Per-sample throttle flags for the data table
$tableRows = ($samples | ForEach-Object {
    $tType = ""
    if ($_.Thermal_Throttle -eq 1 -and $_.Clock_Throttle -eq 1) { $tType = '<span class="badge both">THERMAL + CLOCK</span>' }
    elseif ($_.Thermal_Throttle -eq 1) { $tType = '<span class="badge thermal">THERMAL</span>' }
    elseif ($_.Clock_Throttle   -eq 1) { $tType = '<span class="badge clock">CLOCK DROP</span>' }
    else { $tType = '<span class="badge ok">OK</span>' }
    $rowClass = if ($_.Thermal_Throttle -eq 1 -or $_.Clock_Throttle -eq 1) { ' class="throttle-row"' } else { "" }
    "<tr$rowClass><td>$($_.Timestamp)</td><td>$($_.CPU_Temp_C)</td><td>$($_.CPU_Clock_MHz)</td><td>$($_.CPU_Load_Pct)</td><td>$($_.Fan_RPM)</td><td>$tType</td></tr>"
}) -join "`n"

$cpuName = try { (Get-CimInstance Win32_Processor).Name } catch { "Unknown CPU" }
$hostname = $env:COMPUTERNAME
$testMode = if ($NoStressTest) { "Monitor Only" } else { "Stress Test ($StressThreads threads, ${DurationSeconds}s)" }
$reportDate = Get-Date -Format "dddd, MMMM d yyyy  HH:mm:ss"

$html = @"
