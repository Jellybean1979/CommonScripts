<!-- Manual Search -->
<Grid Grid.Row="2" Margin="0,10,0,0">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>

    <StackPanel Grid.Column="0">
        <Label Content="Manual Computer Search:"/>
        <TextBox x:Name="txtManualSearch"
                 Height="26"
                 Background="#FF102447"
                 Foreground="White"
                 BorderBrush="#FF3C5A8A"
                 BorderThickness="1"
                 Margin="0,0,0,5"
                 ToolTip="Enter a full or partial computer name"/>
    </StackPanel>

    <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Orientation="Horizontal">
        <Button x:Name="btnManualSearch"
                Content="Search"
                Width="100"
                Margin="5,0,0,5"/>
    </StackPanel>
</Grid>





function Search-ManualComputer {
    param([string]$Name, $sync)

    $computerName = $Name.Trim().ToUpper()
    if (-not $computerName) { return }

    # Update UI
    $sync.Window.Dispatcher.Invoke([action]{
        $sync.StatusLabel.Text = "Searching $computerName ..."
        $sync.ProgressBar.Value = 0
    })

    # Log
    $time = (Get-Date).ToString("HH:mm:ss")
    $sync.Window.Dispatcher.Invoke([action]{
        $sync.LogBox.AppendText("[$time] Manual search for: $computerName`r`n")
        $sync.LogBox.ScrollToEnd()
    })

    try {
        $adComp = Get-ADComputer -Filter "Name -like '$computerName*'" -Properties `
            lastLogonTimestamp, lastLogonDate, `
            msDS-LastSuccessfulInteractiveLogonTime, `
            msDS-LastFailedInteractiveLogonTime, `
            OperatingSystem, Description, DistinguishedName, Location `
            -ErrorAction Stop
    } catch {
        $obj = [PSCustomObject]@{
            ComputerName = $computerName
            Location = "NOT FOUND"
            LastLogonTimestamp = "NOT FOUND"
            LastLogonDate = "NOT FOUND"
            LastSuccessfulInteractiveLogonTime = "NOT FOUND"
            LastFailedInteractiveLogonTime = "NOT FOUND"
            OperatingSystem = "NOT FOUND"
            Description = "NOT FOUND"
            DistinguishedName = "NOT FOUND"
        }
        $sync.Window.Dispatcher.Invoke([action]{ $sync.Results.Add($obj) })
        return
    }

    $obj = [PSCustomObject]@{
        ComputerName = $adComp.Name
        Location = $adComp.Location
        LastLogonTimestamp = Convert-ADTime $adComp.lastLogonTimestamp
        LastLogonDate = Convert-ADTime $adComp.lastLogonDate
        LastSuccessfulInteractiveLogonTime = Convert-ADTime $adComp.'msDS-LastSuccessfulInteractiveLogonTime'
        LastFailedInteractiveLogonTime = Convert-ADTime $adComp.'msDS-LastFailedInteractiveLogonTime'
        OperatingSystem = $adComp.OperatingSystem
        Description = $adComp.Description
        DistinguishedName = $adComp.DistinguishedName
    }

    $sync.Window.Dispatcher.Invoke([action]{ $sync.Results.Add($obj) })

    # UI done
    $sync.Window.Dispatcher.Invoke([action]{
        $sync.StatusLabel.Text = "Manual search complete."
        $sync.ProgressBar.Value = 100
        $sync.BtnExport.IsEnabled = $true
    })
}





$btnManualSearch.Add_Click({
    $name = $txtManualSearch.Text.Trim()
    if (-not $name) {
        [System.Windows.MessageBox]::Show("Enter a computer name or partial name.", "Manual Search", 'OK', 'Warning')
        return
    }

    Search-ManualComputer -Name $name -sync $sync
})